// Bitboard data model.
// Core: User -< Post -< Like; User -< Follow >- User (self-referential).
// Side: Notification (fan-out of LIKE/FOLLOW/NEW_POST), ModerationLog (admin audit trail).
// Supabase owns auth; User.id mirrors the Supabase auth user UUID.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Profile row paired 1:1 with a Supabase auth user.
// `status` gates access (SUSPENDED/DELETED blocked in middleware); `role` gates admin routes.
model User {
  id           String     @id @default(uuid())
  email        String     @unique
  username     String     @unique
  nickname     String?
  bio          String?
  avatarColor  String?
  role         Role       @default(USER)
  status       UserStatus @default(ACTIVE)
  suspendedAt  DateTime?
  uiTheme      String     @default("light")
  createdAt    DateTime   @default(now())

  posts                 Post[]
  likes                 Like[]
  followers             Follow[]       @relation("followers")
  following             Follow[]       @relation("following")
  notificationsReceived Notification[] @relation("recipient")
  notificationsSent     Notification[] @relation("sender")
  moderationLogs        ModerationLog[]
}

// A bitmap post. `pixels` is row-major, length = width*height, each value an index into `palette`.
// `frames` is optional animation: JSON array of { pixels: Int[] } sharing the post's width/height/palette.
// `isFlagged` is set when any user reports the post; the admin UI filters on it.
model Post {
  id        String   @id @default(uuid())
  authorId  String
  caption   String?
  width     Int
  height    Int
  pixels    Int[]
  palette   String[]
  hashtags  String[]
  frames    Json?
  isFlagged Boolean  @default(false)
  createdAt DateTime @default(now())

  author        User           @relation(fields: [authorId], references: [id])
  likes         Like[]
  notifications Notification[]
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
}

// Directed follow edge: followerId follows followingId.
// Relation names are reversed so User.followers/User.following read naturally
// (my followers = rows where I'm the followingId, and vice versa).
model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("following", fields: [followerId], references: [id])
  following User @relation("followers", fields: [followingId], references: [id])

  @@unique([followerId, followingId])
}

// sender/post are nullable so notifications survive deletion of either.
// Indexed on (recipientId, createdAt) for the bell dropdown's "latest per user" query.
model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  recipientId String
  senderId    String?
  postId      String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient User  @relation("recipient", fields: [recipientId], references: [id])
  sender    User? @relation("sender", fields: [senderId], references: [id])
  post      Post? @relation(fields: [postId], references: [id])

  @@index([recipientId, createdAt])
}

// Append-only admin audit trail.
// `targetId` is a loose string (may reference a post or a user) — intentionally not a FK so
// the log entry outlives the target row.
model ModerationLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  targetId  String
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum NotificationType {
  LIKE
  FOLLOW
  NEW_POST
}
